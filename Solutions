<style>
/* CSS DESIGN SYSTEM MAPPED FROM YOUR HOMEPAGE */
:root{
  --navy:#102a43; --ink:#08111f; --ink-2:#22324a; --paper:#f5f8fc; --paper-2:#ebf2fb;
  --blue:#0b64dd; --teal:#008b87; --serif:'Playfair Display',serif; --sans:'Figtree',sans-serif;
  --shadow-sm:0 6px 18px rgba(15,39,66,.06); --shadow-md:0 16px 36px rgba(15,39,66,.10);
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--paper);color:var(--ink);font-family:var(--sans);line-height:1.6;}
.container{width:100%;max-width:1180px;margin:0 auto;padding:0 24px;}
.nav{position:sticky;top:0;z-index:100;background:rgba(245,248,252,.92);backdrop-filter:blur(14px);border-bottom:1px solid rgba(8,17,31,.1);}
.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:16px 0}
.brand{display:flex;align-items:center;gap:12px;font-weight:800;font-family:var(--sans);}
.brand-mark{width:40px;height:40px;border-radius:50%;display:grid;place-items:center;font-family:var(--serif);background:linear-gradient(135deg,var(--blue),var(--teal));color:#fff;}
.section{padding:80px 0}
.section-label{font-size:12px;font-weight:800;text-transform:uppercase;color:var(--teal);margin-bottom:1rem;display:block;}
.section-h2{font-family:var(--serif);font-size:clamp(32px,4vw,48px);color:var(--navy);line-height:1.1;margin-bottom:20px;}

/* DASHBOARD VISUALIZATION STYLES */
.dashboard-container {
    background: #102a43;
    border-radius: 18px;
    padding: 24px;
    margin: 40px 0;
    box-shadow: var(--shadow-md);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
}
.db-header { display: flex; justify-content: space-between; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; }
.db-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; }
.db-card { background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; border-left: 4px solid var(--teal); }
.db-val { font-size: 24px; font-weight: 700; color: var(--teal); }
.db-label { font-size: 11px; text-transform: uppercase; opacity: 0.7; }
.db-status { color: #4ade80; font-size: 12px; margin-top: 5px; }

.cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
.info-card{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:18px;padding:2rem;box-shadow:var(--shadow-sm);position:relative;}
.info-card::before{content:"";position:absolute;top:0;left:0;width:100%;height:4px;background:var(--blue);}
.primary-btn{display:inline-flex;padding:12px 24px;background:var(--blue);color:#fff;border-radius:999px;font-size:12px;font-weight:800;text-transform:uppercase;margin-top:15px;}

@media (max-width:900px){ .cards-grid { grid-template-columns: 1fr; } }
</style>
</head>
