<section class="section">
  <div class="container">
    <div class="about-hero">

      <!-- LEFT -->
      <div class="about-left">
        <h2>
          Built for production systems.<br>
          Trusted in partner-led environments.
        </h2>

        <p>
          DinaBridge works with enterprises and consulting partners to deliver
          production-grade observability, search, and data systems.
        </p>

        <a href="./contact.html" class="primary-btn">Contact Us</a>
      </div>

      <!-- RIGHT -->
      <div class="about-grid">
        <div class="avatar"></div>
        <div class="avatar"></div>
        <div class="avatar"></div>
        <div class="avatar"></div>
        <div class="avatar"></div>
        <div class="avatar"></div>
        <div class="avatar"></div>
        <div class="avatar"></div>
      </div>

    </div>
  </div>
</section>

.about-hero {
  background: linear-gradient(135deg, #b92c2c, #8f1f1f);
  border-radius: 28px;
  padding: 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  color: #fff;
}

.about-left h2 {
  font-family: var(--serif);
  font-size: clamp(32px,4vw,44px);
  line-height: 1.1;
  margin-bottom: 1rem;
}

.about-left p {
  margin-bottom: 1.5rem;
  color: rgba(255,255,255,0.9);
}

.about-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.avatar {
  width: 100%;
  aspect-ratio: 1/1;
  border-radius: 18px;
  background: rgba(255,255,255,0.08);
}
@media (max-width: 900px) {
  .about-hero {
    grid-template-columns: 1fr;
  }
}
background: linear-gradient(135deg, var(--blue), var(--teal));

